# Cloud Field Campaign Scorecard - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGINS=*

# ============================================
# Tableau API (Optional)
# ============================================
TABLEAU_SERVER_URL=https://prod-uswest-c.online.tableau.com
TABLEAU_SITE_ID=salesforce
TABLEAU_TOKEN_NAME=your_token_name
TABLEAU_TOKEN_VALUE=your_token_value

# ============================================
# Slack API (Optional)
# ============================================
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_CHANNEL_ID=C123456789

# ============================================
# Database (Heroku Postgres - Auto-configured)
# ============================================
# DATABASE_URL will be automatically set by Heroku

# ============================================
# Google Slides API (Optional)
# ============================================
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# ============================================
# Security
# ============================================
# API_SECRET_KEY=your-secret-key-here
