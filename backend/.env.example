# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/scorecard_db

# Tableau API Configuration
TABLEAU_SERVER_URL=https://prod-uswest-c.online.tableau.com
TABLEAU_SITE_ID=salesforce
TABLEAU_TOKEN_NAME=your_token_name
TABLEAU_TOKEN_VALUE=your_token_value_here
TABLEAU_API_VERSION=3.19

# Tableau Workbook IDs (to be filled)
TABLEAU_WORKBOOK_MDP_SCORECARD=1534752
TABLEAU_WORKBOOK_LEAD_PERFORMANCE=
TABLEAU_WORKBOOK_CAMPAIGN_PERFORMANCE=

# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=C123456789  # Channel ID for broadcast channel
SLACK_APP_TOKEN=xapp-your-app-token

# Google Cloud Configuration (for Slides export)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-service-account.json
GOOGLE_SLIDES_TEMPLATE_ID=your_template_presentation_id

# API Configuration
API_SECRET_KEY=your-secret-key-min-32-chars-change-this-in-production
API_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis (for Celery task queue)
REDIS_URL=redis://localhost:6379/0

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Environment
ENVIRONMENT=development
DEBUG=True

# Logging
LOG_LEVEL=INFO
